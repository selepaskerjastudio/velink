# Agent configuration. The installer writes this to /etc/coruncloud/agent.env
# and the systemd unit loads it via EnvironmentFile.

# Gateway WebSocket base URL (no trailing /agent/connect).
AGENT_GATEWAY_URL=wss://panel.example.com:8080

# Per-server enrollment token (shown once in the panel's "Add Server" page).
AGENT_TOKEN=

# This server's panel ID.
AGENT_SERVER_ID=

# Heartbeat interval in seconds.
AGENT_HEARTBEAT=30

# Set to 1 to skip TLS verification (dev only).
AGENT_INSECURE=0
