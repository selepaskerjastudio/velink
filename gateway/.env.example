# Gateway configuration (export these or use a process manager / systemd unit).

# host:port the gateway binds to for agent WSS connections.
GATEWAY_LISTEN=:8080

# Base URL of the Laravel panel internal API (token verification).
GATEWAY_PANEL_URL=http://127.0.0.1:8000

# Shared secret. MUST match GATEWAY_SECRET in panel/.env.
GATEWAY_PANEL_SECRET=change-me

# Redis shared with the panel (same instance Laravel uses).
GATEWAY_REDIS_ADDR=127.0.0.1:6379
GATEWAY_REDIS_PASSWORD=
GATEWAY_REDIS_DB=0

# Seconds a server stays "online" without a heartbeat.
GATEWAY_PRESENCE_TTL=90
