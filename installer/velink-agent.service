[Unit]
Description=Velink agent
Documentation=https://github.com/selepaskerjastudio/velink
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/velink/agent.env
ExecStart=/usr/local/bin/velink-agent
Restart=always
RestartSec=5
# The agent provisions packages/services, so it runs privileged.
User=root
AmbientCapabilities=CAP_NET_BIND_SERVICE
NoNewPrivileges=no

[Install]
WantedBy=multi-user.target
